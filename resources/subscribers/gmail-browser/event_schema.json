{
  "version": 1,
  "event_source": "gmail-browser",
  "text_fields": [
    { "path": "message.sender", "label": "Sender" },
    { "path": "message.subject", "label": "Subject" },
    { "path": "message.snippet", "label": "Snippet" }
  ],
  "fields": [
    {
      "path": "message.sender",
      "label": "Sender name",
      "type": "string",
      "operators": ["contains", "equals", "matches"]
    },
    {
      "path": "message.fromEmail",
      "label": "From email",
      "type": "string",
      "operators": ["contains", "equals", "matches"]
    },
    {
      "path": "message.subject",
      "label": "Subject",
      "type": "string",
      "operators": ["contains", "equals", "matches"]
    },
    {
      "path": "message.snippet",
      "label": "Snippet",
      "type": "string",
      "operators": ["contains", "equals", "matches"]
    },
    {
      "path": "message.unread",
      "label": "Unread",
      "type": "boolean",
      "operators": ["equals"],
      "values": [
        { "value": true, "label": "Yes" },
        { "value": false, "label": "No" }
      ]
    },
    {
      "path": "message.hasAttachment",
      "label": "Has attachment",
      "type": "boolean",
      "operators": ["equals"],
      "values": [
        { "value": true, "label": "Yes" },
        { "value": false, "label": "No" }
      ]
    }
  ]
}
